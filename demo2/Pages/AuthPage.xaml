<Page x:Class="demo2.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация">

    <Grid Background="White">
        <StackPanel Background="#00FA9A" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image Source="/Images/62931.png" Width="50" Height="50" />
            <TextBlock FontFamily="Times New Roman" HorizontalAlignment="Center" FontSize="24">АВТОРИЗАЦИЯ</TextBlock>
                <TextBlock HorizontalAlignment="Center">Логин</TextBlock>
            <TextBox x:Name="LoginTxt" Height="25" Width="200" Margin="10">

            </TextBox>
            <TextBlock HorizontalAlignment="Center">Пароль</TextBlock>
            <TextBox x:Name="PasswordTxt" Height="25" Width="200" Margin="10">

            </TextBox>
            <Button Margin="10" Height="24" Width="150" Content="Войти" Click="Button_Click_1"/>
            <Button Margin="10" Height="24" Width="150" Content="Войти как гость" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>

<Page x:Class="demo2.Pages.EditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditProductPage">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" BorderBrush="Black" BorderThickness="2" CornerRadius="5" Padding="20" Width="350">
            <StackPanel>
                <TextBlock Text="Редактирование товара" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock Text="Наименование товара:"/>
                <TextBox x:Name="TxtName" Margin="0,0,0,10" Height="25"/>

                <TextBlock Text="Артикул (число):"/>
                <TextBox x:Name="TxtArticul" Margin="0,0,0,10" Height="25"/>

                <TextBlock Text="Цена (руб.):"/>
                <TextBox x:Name="TxtPrice" Margin="0,0,0,10" Height="25"/>

                <TextBlock Text="Скидка (%):"/>
                <TextBox x:Name="TxtDiscount" Margin="0,0,0,10" Height="25"/>

                <TextBlock Text="Описание:"/>
                <TextBox x:Name="TxtDescription" Height="60" TextWrapping="Wrap" Margin="0,0,0,15" AcceptsReturn="True"/>

                    <Button Content="Сохранить" Click="BtnSave_Click" Height="30" Margin="5"/>
                    <Button Content="Отмена" Click="BtnCancel_Click" Height="30" Margin="5"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

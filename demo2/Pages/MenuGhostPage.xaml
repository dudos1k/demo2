<Page x:Class="demo2.Pages.MenuGhostPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MenuGhostPage"
      Background="Khaki"
      Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <!--  ВЕРХНЯЯ ПАНЕЛЬ (Строка 0)  -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
            <Button Content="Назад" Click="Button_Click" Width="80" Height="30"/>
            <!--<TextBlock Width="400" HorizontalAlignment="Right" Text="{Binding users.FIO}" Foreground="Black"/>-->
        </StackPanel>
        <!--  СПИСОК ТОВАРОВ (Строка 1)  -->
        <ListView x:Name="DataGrProduct" Grid.Row="1" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <!--  Карточка товара  -->
                    <Border BorderBrush="Black" BorderThickness="2" Height="130" Margin="5" Background="White">
                        <Grid Margin="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <!--  Левая колонка (Фото)  -->
                            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Margin="2">
                                <Image Source="/Images/62931.png" />
                            </Border>
                            <!--  Средняя колонка (Данные)  -->
                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1" Margin="2" Padding="8,4">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name_pr}" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Articul, StringFormat='Артикул: {0}'}"/>
                                    <TextBlock Text="{Binding Discription, StringFormat='Описание: {0}'}" TextWrapping="Wrap" MaxHeight="35"/>
                                    <TextBlock Text="{Binding Price, StringFormat='Цена: {0} руб.'}"/>
                                </StackPanel>
                            </Border>
                            <!--  Правая колонка (Скидка)  -->
                            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1" Margin="2">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Скидка:" FontSize="10" Foreground="Gray"/>
                                    <TextBlock Text="{Binding Discount, StringFormat={}{0}%}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
